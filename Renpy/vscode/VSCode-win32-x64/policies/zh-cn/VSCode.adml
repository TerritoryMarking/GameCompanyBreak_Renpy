<policyDefinitionResources revision="1.0" schemaVersion="1.0">
	<displayName />
	<description />
	<resources>
		<stringTable>
			<string id="Application">Visual Studio Code</string>
			<string id="Supported_1_101">Visual Studio Code &gt;= 1.101</string>
			<string id="Supported_1_104">Visual Studio Code &gt;= 1.104</string>
			<string id="Supported_1_107">Visual Studio Code &gt;= 1.107</string>
			<string id="Supported_1_109">Visual Studio Code &gt;= 1.109</string>
			<string id="Supported_1_110">Visual Studio Code &gt;= 1.110</string>
			<string id="Supported_1_112">Visual Studio Code &gt;= 1.112</string>
			<string id="Supported_1_113">Visual Studio Code &gt;= 1.113</string>
			<string id="Supported_1_116">Visual Studio Code &gt;= 1.116</string>
			<string id="Supported_1_118">Visual Studio Code &gt;= 1.118</string>
			<string id="Supported_1_121">Visual Studio Code &gt;= 1.121</string>
			<string id="Supported_1_122">Visual Studio Code &gt;= 1.122</string>
			<string id="Supported_1_125">Visual Studio Code &gt;= 1.125</string>
			<string id="Supported_1_67">Visual Studio Code &gt;= 1.67</string>
			<string id="Supported_1_96">Visual Studio Code &gt;= 1.96</string>
			<string id="Supported_1_99">Visual Studio Code &gt;= 1.99</string>
			<string id="Category_interactiveSessionConfigurationTitle">交互式会话</string>
			<string id="Category_extensionsConfigurationTitle">扩展</string>
			<string id="Category_terminalIntegratedConfigurationTitle">集成终端</string>
			<string id="Category_telemetryConfigurationTitle">遥测</string>
			<string id="Category_updateConfigurationTitle">更新</string>
			<string id="BrowserChatTools">BrowserChatTools</string>
			<string id="BrowserChatTools_browser_enableChatTools">启用后，聊天代理可使用浏览器工具打开集成浏览器中的页面并进行交互。</string>
			<string id="ChatAgentAllowedNetworkDomains">ChatAgentAllowedNetworkDomains</string>
			<string id="ChatAgentAllowedNetworkDomains_chat_agent_allowedNetworkDomains">智能体工具(获取工具、集成浏览器)允许进行网络访问的域。在启用 {0} 或 {1} 时应用。当 {1} 设置为 {2} 时，允许所有域。支持 {3} 等通配符。允许列表和拒绝列表均为空时，所有域均被阻止。拒绝的域(请参阅{4})优先。</string>
			<string id="ChatAgentDeniedNetworkDomains">ChatAgentDeniedNetworkDomains</string>
			<string id="ChatAgentDeniedNetworkDomains_chat_agent_deniedNetworkDomains">智能体工具(获取工具、集成浏览器)拒绝进行网络访问的域。在启用 {0} 或 {1} 时应用。当 {1} 设置为 {2} 时不适用。优先于 {3}。支持 {4} 等通配符。</string>
			<string id="ChatAgentExtensionTools">ChatAgentExtensionTools</string>
			<string id="ChatAgentExtensionTools_chat_extensionToolsEnabled">使用由第三方扩展提供的工具启用。</string>
			<string id="ChatAgentMode">ChatAgentMode</string>
			<string id="ChatAgentMode_chat_agent_enabled_description">启用后，可以从聊天中激活智能体模式，并且可以使用智能体上下文中带有副作用的工具。</string>
			<string id="ChatAgentNetworkFilter">ChatAgentNetworkFilter</string>
			<string id="ChatAgentNetworkFilter_chat_agent_networkFilter">启用后，智能体工具(提取工具、集成浏览器)的网络访问将根据 {0} 和 {1} 进行限制。启用 {2} 时，域筛选也会应用于这些工具。</string>
			<string id="ChatApprovedAccountOrganizations">ChatApprovedAccountOrganizations</string>
			<string id="ChatApprovedAccountOrganizations_chat_approvedAccountOrganizations_policy_description">将此策略设置为非空列表会激活已批准帐户限制: 所有 AI 功能将被禁用，直到用户登录的 GitHub 帐户所属组织与该列表存在交集，并且帐户端策略数据已解析。比较不区分大小写。使用 "*" 作为通配符，接受任何已登录的 GitHub 或 GHE 帐户(适用于未显示组织列表的 GHE 部署)。</string>
			<string id="ChatEnabledPlugins">ChatEnabledPlugins</string>
			<string id="ChatEnabledPlugins_chat_plugins_enabledPlugins_policy">插件启用。键是 `<plugin>@<marketplace>` 形式的插件 ID；值用于启用或禁用插件。</string>
			<string id="ChatExtraMarketplaces">ChatExtraMarketplaces</string>
			<string id="ChatExtraMarketplaces_chat_plugins_extraMarketplaces_policy">要查询的其他插件市场。键是市场名称；值是 GitHub 速记(`owner/repo[#ref]`)或 Git URI (`<url>[#ref]`)。</string>
			<string id="ChatHooks">ChatHooks</string>
			<string id="ChatHooks_chat_useHooks_description">控制聊天挂钩是否在智能体工作流的关键节点执行。挂钩从 `#chat.hookFilesLocations#` 中配置的文件加载。</string>
			<string id="ChatMCP">ChatMCP</string>
			<string id="ChatMCP_chat_mcp_access">控制对已安装的模型上下文协议服务器的访问。</string>
			<string id="ChatMCP_chat_mcp_access_none">无法访问 MCP 服务器。</string>
			<string id="ChatMCP_chat_mcp_access_registry">允许访问 VS Code 连接到的注册表中安装的 MCP 服务器。</string>
			<string id="ChatMCP_chat_mcp_access_any">允许访问任何已安装的 MCP 服务器。</string>
			<string id="ChatPluginsEnabled">ChatPluginsEnabled</string>
			<string id="ChatPluginsEnabled_chat_plugins_enabled">在聊天中启用智能体插件集成。</string>
			<string id="ChatStrictMarketplaces">ChatStrictMarketplaces</string>
			<string id="ChatStrictMarketplaces_chat_plugins_strictMarketplaces_policy">仅信任通过企业策略提供的市场；不会加载来自任何其他市场的插件。</string>
			<string id="ChatToolsAutoApprove">ChatToolsAutoApprove</string>
			<string id="ChatToolsAutoApprove_autoApprove3_description">全局自动批准也称为“YOLO 模式”，它会完全禁用对所有工作区中所有工具的手动审批，从而允许智能体完全自主地执行操作。此操作极为危险，并且“从不”建议使用，因为即使是 Codespaces 和开发容器等容器化环境也会将用户密钥转发到可能遭到入侵的容器中。

此功能会禁用关键安全保护，并导致攻击者能够更容易地入侵计算机。

注意: 此设置仅控制工具审批，不会阻止智能体提问。要自动回答智能体的问题，请使用 `#chat.autoReply#` 设置。</string>
			<string id="ChatToolsEligibleForAutoApproval">ChatToolsEligibleForAutoApproval</string>
			<string id="ChatToolsEligibleForAutoApproval_chat_tools_eligibleForAutoApproval">控制哪些工具有资格获得自动批准。设置为 `false` 的工具将始终提出确认，且从不提供自动批准选项。默认行为(或将工具设置为 `true`)可能使工具提供自动批准选项。</string>
			<string id="Claude3PIntegration">Claude3PIntegration</string>
			<string id="Claude3PIntegration_github_copilot_chat_claudeAgent_enabled">Enable Claude Agent sessions in VS Code. Start and resume agentic coding sessions powered by Anthropic Claude Agent SDK directly in the editor. Uses your existing Copilot subscription.</string>
			<string id="CopilotNextEditSuggestions">CopilotNextEditSuggestions</string>
			<string id="CopilotNextEditSuggestions_github_copilot_nextEditSuggestions_enabled">Whether to enable next edit suggestions (NES). NES can propose a next edit based on your recent changes.</string>
			<string id="CopilotReviewAgent">CopilotReviewAgent</string>
			<string id="CopilotReviewAgent_github_copilot_chat_reviewAgent_enabled">Enables the code review agent.</string>
			<string id="CopilotReviewSelection">CopilotReviewSelection</string>
			<string id="CopilotReviewSelection_github_copilot_chat_reviewSelection_enabled">Enables code review on current selection.</string>
			<string id="CopilotSessionSync">CopilotSessionSync</string>
			<string id="CopilotSessionSync_chat_sessionSync_enabled_policy">启用与 GitHub.com 的会话同步，以实现跨设备的 Copilot 会话历史记录共享。如果被组织策略禁用，则会话数据仅保留在本地。</string>
			<string id="DeprecatedEditModeHidden">DeprecatedEditModeHidden</string>
			<string id="DeprecatedEditModeHidden_chat_editMode_hidden">启用后，在聊天模式选取器中隐藏编辑模式。</string>
			<string id="McpEnterpriseManagedAuthIdp">McpEnterpriseManagedAuthIdp</string>
			<string id="McpEnterpriseManagedAuthIdp_mcp_enterpriseManagedAuth_idp_policy">用于企业管理的模型上下文协议(MCP)服务器身份验证的 OAuth/OIDC IdP 配置。通过企业策略(Windows 组策略、macOS 托管首选项、Linux `/etc/vscode/policy.json`) 提供。</string>
			<string id="McpGalleryServiceUrl">McpGalleryServiceUrl</string>
			<string id="McpGalleryServiceUrl_mcp_gallery_serviceUrl">配置 MCP 库服务 URL 以连接到以下位置:</string>
			<string id="AllowedExtensions">AllowedExtensions</string>
			<string id="AllowedExtensions_extensions_allowed_policy">指定允许使用的扩展列表。这有助于通过限制使用未经授权的扩展来维护安全且一致的开发环境。详细信息: https://aka.ms/vscode/enterprise/extensions/allowed</string>
			<string id="ExtensionGalleryServiceUrl">ExtensionGalleryServiceUrl</string>
			<string id="ExtensionGalleryServiceUrl_extensions_gallery_serviceUrl">配置要连接到的市场服务 URL</string>
			<string id="ExtensionsAutoUpdate">ExtensionsAutoUpdate</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate">控制扩展的自动更新行为。更新是从 Microsoft 联机服务中获取的。</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate_on">Download and install updates automatically only for enabled extensions.</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate_off">Extensions are not automatically updated.</string>
			<string id="ExtensionsAutoUpdateDelay">ExtensionsAutoUpdateDelay</string>
			<string id="ExtensionsAutoUpdateDelay_extensions_autoUpdateDelay">Controls the delay in hours after an extension update is published before it is automatically installed. Only applies when `#extensions.autoUpdate#` is set to `on`. This delay helps avoid installing potentially problematic updates immediately after release.</string>
			<string id="ChatAgentSandboxAllowAutoApprove">ChatAgentSandboxAllowAutoApprove</string>
			<string id="ChatAgentSandboxAllowAutoApprove_agentSandbox_allowAutoApprove">控制是否自动批准在沙盒内运行的智能体模式终端命令。禁用时，“在终端中运行”工具将使用现有审批流程。仅当启用 {0} 时适用。</string>
			<string id="ChatAgentSandboxAllowUnsandboxedCommands">ChatAgentSandboxAllowUnsandboxedCommands</string>
			<string id="ChatAgentSandboxAllowUnsandboxedCommands_agentSandbox_allowUnsandboxedCommands">控制当沙盒命令失败或沙盒限制会阻止命令时，智能体模式终端命令在用户确认后是否可在沙盒外运行。仅当启用 {0} 时适用。</string>
			<string id="ChatAgentSandboxAutoApproveUnsandboxedCommands">ChatAgentSandboxAutoApproveUnsandboxedCommands</string>
			<string id="ChatAgentSandboxAutoApproveUnsandboxedCommands_agentSandbox_autoApproveUnsandboxedCommands">控制是否自动批准在沙盒外运行的智能体模式终端命令。仅当同时启用 {0} 和 {1} 时适用。</string>
			<string id="ChatAgentSandboxEnabled">ChatAgentSandboxEnabled</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting">控制智能体模式是否使用沙盒来限制工具的操作。启用后，终端等工具将在沙盒环境中运行，以限制对系统的访问。</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_offDescription">为代理模式工具禁用沙盒。</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_onDescription">为代理模式工具启用沙盒。</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_allowNetworkDescription">为智能体模式工具启用沙盒，并允许所有网络域。</string>
			<string id="ChatToolsTerminalEnableAutoApprove">ChatToolsTerminalEnableAutoApprove</string>
			<string id="ChatToolsTerminalEnableAutoApprove_autoApproveMode_description">控制在终端工具中的运行中是否允许自动审批。</string>
			<string id="EnableFeedback">EnableFeedback</string>
			<string id="EnableFeedback_telemetry_feedback_enabled">启用反馈机制，例如问题报告器、调查和其他反馈选项。</string>
			<string id="TelemetryLevel">TelemetryLevel</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_policyDescription">控制遥测级别。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_default">发送使用情况数据、错误、故障报告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_error">发送常规错误遥测和故障报告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_crash">发送 OS 级别故障报告。</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_off">禁用所有产品遥测。</string>
			<string id="UpdateMode">UpdateMode</string>
			<string id="UpdateMode_updateMode">配置是否接收自动更新。更改后需要重新启动。更新是从微软在线服务获取的。</string>
			<string id="UpdateMode_none">无</string>
			<string id="UpdateMode_manual">禁用自动后台更新检查。如果手动检查更新，更新将可用。</string>
			<string id="UpdateMode_start">启动</string>
			<string id="UpdateMode_default">系统</string>
		</stringTable>
		<presentationTable>
			<presentation id="BrowserChatTools"><checkBox refId="BrowserChatTools">BrowserChatTools</checkBox></presentation>
			<presentation id="ChatAgentAllowedNetworkDomains"><multiTextBox refId="ChatAgentAllowedNetworkDomains" /></presentation>
			<presentation id="ChatAgentDeniedNetworkDomains"><multiTextBox refId="ChatAgentDeniedNetworkDomains" /></presentation>
