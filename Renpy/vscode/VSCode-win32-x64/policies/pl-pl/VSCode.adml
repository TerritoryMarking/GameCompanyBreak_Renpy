			<string id="Category_interactiveSessionConfigurationTitle">Sesja interakcyjna</string>
			<string id="Category_extensionsConfigurationTitle">Rozszerzenia</string>
			<string id="Category_terminalIntegratedConfigurationTitle">Zintegrowany terminal</string>
			<string id="Category_telemetryConfigurationTitle">Telemetria</string>
			<string id="Category_updateConfigurationTitle">Aktualizuj</string>
			<string id="BrowserChatTools">BrowserChatTools</string>
			<string id="BrowserChatTools_browser_enableChatTools">Po włączeniu tej opcji agenci czatu mogą używać narzędzi przeglądarki do otwierania stron i interakcji z nimi w zintegrowanej przeglądarce.</string>
			<string id="ChatAgentAllowedNetworkDomains">ChatAgentAllowedNetworkDomains</string>
			<string id="ChatAgentAllowedNetworkDomains_chat_agent_allowedNetworkDomains">Dozwolone domeny dla dostępu do sieci przez narzędzia agenta (narzędzie do pobierania, zintegrowana przeglądarka). Działa tylko, gdy włączono {0} lub {1}. Gdy wartość elementu {1} jest ustawiona na{2}, wszystkie domeny są dozwolone. Obsługuje symbole wieloznaczne, takie jak {3}. Jeśli obie listy — dozwolonych i zablokowanych — są puste, wszystkie domeny są blokowane. Domeny zablokowane (zobacz {4}) mają pierwszeństwo.</string>
			<string id="ChatAgentDeniedNetworkDomains">ChatAgentDeniedNetworkDomains</string>
			<string id="ChatAgentDeniedNetworkDomains_chat_agent_deniedNetworkDomains">Odmowa domen dostępu do sieci przez narzędzia agenta (narzędzie do pobierania, zintegrowana przeglądarka). Działa tylko, gdy włączono {0} lub {1}. Nie dotyczy, gdy wartość elementu {1} jest ustawiona na {2}. Ma pierwszeństwo przed {3}. Obsługuje symbole wieloznaczne, takie jak {4}.</string>
			<string id="ChatAgentExtensionTools">ChatAgentExtensionTools</string>
			<string id="ChatAgentExtensionTools_chat_extensionToolsEnabled">Włącz korzystanie z narzędzi dostarczonych przez rozszerzenia innych firm.</string>
			<string id="ChatAgentMode">ChatAgentMode</string>
			<string id="ChatAgentMode_chat_agent_enabled_description">Po włączeniu tryb agenta można aktywować z poziomu czatu, a narzędzia w kontekstach agentowych z efektami ubocznymi mogą być używane.</string>
			<string id="ChatAgentNetworkFilter">ChatAgentNetworkFilter</string>
			<string id="ChatAgentNetworkFilter_chat_agent_networkFilter">Po włączeniu dostęp do sieci przez narzędzia agenta (narzędzie do pobierania, zintegrowana przeglądarka) jest ograniczony zgodnie z {0} i {1}. Filtrowanie domen jest też stosowane do tych narzędzi, gdy {2} jest włączone.</string>
			<string id="ChatApprovedAccountOrganizations">ChatApprovedAccountOrganizations</string>
			<string id="ChatApprovedAccountOrganizations_chat_approvedAccountOrganizations_policy_description">Ustawienie tych zasad na listę zawierającą co najmniej jeden wpis powoduje aktywację mechanizmu „zatwierdzonych kont”: wszystkie funkcje AI są wyłączone do momentu, gdy użytkownik zaloguje się na konto w serwisie GitHub, którego organizacje pokrywają się z tą listą ORAZ dane dotyczące zasad po stronie konta zostaną zweryfikowane. W porównaniu nie jest uwzględniana wielkość liter. Użyj znaku „*” jako symbolu wieloznacznego, aby zaakceptować dowolne zalogowane konto w serwisie GitHub lub GHE (użyj tej opcji w przypadku wdrożeń w GHE, gdzie lista organizacji nie jest widoczna).</string>
			<string id="ChatEnabledPlugins">ChatEnabledPlugins</string>
			<string id="ChatEnabledPlugins_chat_plugins_enabledPlugins_policy">Włączanie wtyczki. Klucze to identyfikatory wtyczek w formacie `<plugin>@<marketplace>`, a wartości włączają lub wyłączają wtyczkę.</string>
			<string id="ChatExtraMarketplaces">ChatExtraMarketplaces</string>
			<string id="ChatExtraMarketplaces_chat_plugins_extraMarketplaces_policy">Dodatkowe witryny marketplace wtyczek do wykonywania zapytań. Klucze to nazwy rynków; wartości to skróty GitHub (`owner/repo[#ref]`) lub identyfikatory URI Git (`<url>[#ref]`).</string>
			<string id="ChatHooks">ChatHooks</string>
			<string id="ChatHooks_chat_useHooks_description">Określa, czy punkty zaczepienia czatu są wykonywane w strategicznych momentach podczas przepływu pracy agenta. Punkty zaczepienia są ładowane z plików skonfigurowanych w `#chat.hookFilesLocations#`.</string>
			<string id="ChatMCP">ChatMCP</string>
			<string id="ChatMCP_chat_mcp_access">Steruje dostępem do zainstalowanych serwerów protokołu kontekstowego modelu.</string>
			<string id="ChatMCP_chat_mcp_access_none">Brak dostępu do serwerów MCP.</string>
			<string id="ChatMCP_chat_mcp_access_registry">Umożliwia dostęp do serwerów MCP zainstalowanych z rejestru, z którą jest połączony program VS Code.</string>
			<string id="ChatMCP_chat_mcp_access_any">Zezwalaj na dostęp do dowolnego zainstalowanego serwera MCP.</string>
			<string id="ChatPluginsEnabled">ChatPluginsEnabled</string>
			<string id="ChatPluginsEnabled_chat_plugins_enabled">Włącz integrację wtyczki agenta na czacie.</string>
			<string id="ChatStrictMarketplaces">ChatStrictMarketplaces</string>
			<string id="ChatStrictMarketplaces_chat_plugins_strictMarketplaces_policy">Ufaj tylko rynkom dostarczanym za pośrednictwem zasad Enterprise; wtyczki z innych rynków nie zostaną załadowane.</string>
			<string id="ChatToolsAutoApprove">ChatToolsAutoApprove</string>
			<string id="ChatToolsAutoApprove_autoApprove3_description">Globalne automatyczne zatwierdzanie nazywane również „trybem YOLO” powoduje całkowite wyłączenie ręcznego zatwierdzania dla wszystkich narzędzi we wszystkich obszarach roboczych, co pozwala agentowi działać w pełni autonomicznie. Jest to bardzo niebezpieczne i *nigdy* nie jest rekomendowane, nawet w środowiskach konteneryzowanych, takich jak Codespaces i Dev Containers, klucze użytkownika są przekazywane do kontenera, który może zostać naruszony.

Ta funkcja wyłącza krytyczne zabezpieczenia i znacznie ułatwia osobie atakującej naruszenie zabezpieczeń maszyny.

Uwaga: to ustawienie steruje tylko zatwierdzaniem narzędzi i nie uniemożliwia agentowi zadawania pytań. Aby automatycznie odpowiadać na pytania agenta, użyj tego ustawienia `#chat.autoReply#`.</string>
			<string id="ChatToolsEligibleForAutoApproval">ChatToolsEligibleForAutoApproval</string>
			<string id="ChatToolsEligibleForAutoApproval_chat_tools_eligibleForAutoApproval">Określa, które narzędzia kwalifikują się do automatycznego zatwierdzania. Narzędzia ustawione na wartość „false” zawsze będą przedstawiać potwierdzenie i nigdy nie będą oferować opcji automatycznego zatwierdzania. Domyślne zachowanie (lub ustawienie narzędzia na wartość „true”) może spowodować, że narzędzie będzie oferować opcje automatycznego zatwierdzania.</string>
			<string id="Claude3PIntegration">Claude3PIntegration</string>
			<string id="Claude3PIntegration_github_copilot_chat_claudeAgent_enabled">Enable Claude Agent sessions in VS Code. Start and resume agentic coding sessions powered by Anthropic Claude Agent SDK directly in the editor. Uses your existing Copilot subscription.</string>
			<string id="CopilotNextEditSuggestions">CopilotNextEditSuggestions</string>
			<string id="CopilotNextEditSuggestions_github_copilot_nextEditSuggestions_enabled">Whether to enable next edit suggestions (NES). NES can propose a next edit based on your recent changes.</string>
			<string id="CopilotReviewAgent">CopilotReviewAgent</string>
			<string id="CopilotReviewAgent_github_copilot_chat_reviewAgent_enabled">Enables the code review agent.</string>
			<string id="CopilotReviewSelection">CopilotReviewSelection</string>
			<string id="CopilotReviewSelection_github_copilot_chat_reviewSelection_enabled">Enables code review on current selection.</string>
			<string id="CopilotSessionSync">CopilotSessionSync</string>
			<string id="CopilotSessionSync_chat_sessionSync_enabled_policy">Włącz synchronizację sesji z GitHub.com, aby korzystać z historii sesji Copilot na różnych urządzeniach. Jeśli zgodnie z zasadami organizacji ta opcja zostanie wyłączona, dane sesji będą przechowywane tylko lokalnie.</string>
			<string id="DeprecatedEditModeHidden">DeprecatedEditModeHidden</string>
			<string id="DeprecatedEditModeHidden_chat_editMode_hidden">Po włączeniu tej opcji, ukrywa tryb edycji w selektorze trybu czatu.</string>
			<string id="McpEnterpriseManagedAuthIdp">McpEnterpriseManagedAuthIdp</string>
			<string id="McpEnterpriseManagedAuthIdp_mcp_enterpriseManagedAuth_idp_policy">Konfiguracja protokołu IdP protokołu OAuth/OIDC używana do uwierzytelniania serwera zarządzanego przez przedsiębiorstwo protokołu MCP (Model Context Protocol). Dostarczana za pośrednictwem zasad Enterprise (zasady grupy systemu Windows, zarządzane preferencje systemu macOS, Linux `/etc/vscode/policy.json`).</string>
			<string id="McpGalleryServiceUrl">McpGalleryServiceUrl</string>
			<string id="McpGalleryServiceUrl_mcp_gallery_serviceUrl">Skonfiguruj adres URL usługi MCP Gallery, aby nawiązać połączenie z</string>
			<string id="AllowedExtensions">AllowedExtensions</string>
			<string id="AllowedExtensions_extensions_allowed_policy">Określ listę rozszerzeń, które mogą być używane. Pomaga to zachować bezpieczne i spójne środowisko programistyczne, ograniczając użycie nieautoryzowanych rozszerzeń. Więcej informacji: https://aka.ms/vscode/enterprise/extensions/allowed</string>
			<string id="ExtensionGalleryServiceUrl">ExtensionGalleryServiceUrl</string>
			<string id="ExtensionGalleryServiceUrl_extensions_gallery_serviceUrl">Konfigurowanie adresu URL usługi Marketplace w celu nawiązania połączenia z</string>
			<string id="ExtensionsAutoUpdate">ExtensionsAutoUpdate</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate">Steruje działaniem automatycznej aktualizacji rozszerzeń. Aktualizacje są pobierane z usługi online firmy Microsoft.</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate_on">Download and install updates automatically only for enabled extensions.</string>
			<string id="ExtensionsAutoUpdate_extensions_autoUpdate_off">Extensions are not automatically updated.</string>
			<string id="ExtensionsAutoUpdateDelay">ExtensionsAutoUpdateDelay</string>
			<string id="ExtensionsAutoUpdateDelay_extensions_autoUpdateDelay">Controls the delay in hours after an extension update is published before it is automatically installed. Only applies when `#extensions.autoUpdate#` is set to `on`. This delay helps avoid installing potentially problematic updates immediately after release.</string>
			<string id="ChatAgentSandboxAllowAutoApprove">ChatAgentSandboxAllowAutoApprove</string>
			<string id="ChatAgentSandboxAllowAutoApprove_agentSandbox_allowAutoApprove">Określa, czy polecenia terminalu w trybie agenta uruchamiane w piaskownicy są automatycznie zatwierdzane. Gdy ta opcja jest wyłączona, narzędzie uruchamiania w terminalu używa istniejącego przepływu zatwierdzania. Dotyczy to tylko sytuacji, gdy {0} jest włączony.</string>
			<string id="ChatAgentSandboxAllowUnsandboxedCommands">ChatAgentSandboxAllowUnsandboxedCommands</string>
			<string id="ChatAgentSandboxAllowUnsandboxedCommands_agentSandbox_allowUnsandboxedCommands">Określa, czy polecenia terminalu w trybie agenta mogą być uruchamiane poza piaskownicą po potwierdzeniu przez użytkownika, gdy polecenie w piaskownicy zakończy się niepowodzeniem lub gdy ograniczenia piaskownicy zablokują polecenie. Dotyczy to tylko sytuacji, gdy {0} jest włączony.</string>
			<string id="ChatAgentSandboxAutoApproveUnsandboxedCommands">ChatAgentSandboxAutoApproveUnsandboxedCommands</string>
			<string id="ChatAgentSandboxAutoApproveUnsandboxedCommands_agentSandbox_autoApproveUnsandboxedCommands">Określa, czy polecenia terminalu trybu agenta uruchamiane poza piaskownicą są zatwierdzane automatycznie. Ma to zastosowanie tylko wtedy, gdy są włączone zarówno {0}, jak i {1}.</string>
			<string id="ChatAgentSandboxEnabled">ChatAgentSandboxEnabled</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting">Określa, czy tryb agenta używa piaskownicy, aby ograniczyć możliwości narzędzi. Po włączeniu narzędzia, takie jak terminal, są uruchamiane w środowisku w trybie piaskownicy w celu ograniczenia dostępu do systemu.</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_offDescription">Wyłącz piaskownicę dla narzędzi trybu agenta.</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_onDescription">Włącz piaskownicę dla narzędzi trybu agenta.</string>
			<string id="ChatAgentSandboxEnabled_agentSandbox_enabledSetting_allowNetworkDescription">Włącz piaskownicę dla narzędzi w trybie agenta i zezwól na wszystkie domeny sieciowe.</string>
			<string id="ChatToolsTerminalEnableAutoApprove">ChatToolsTerminalEnableAutoApprove</string>
			<string id="ChatToolsTerminalEnableAutoApprove_autoApproveMode_description">Określa, czy zezwalać na automatyczne zatwierdzanie w narzędziu uruchamiania w terminalu.</string>
			<string id="EnableFeedback">EnableFeedback</string>
			<string id="EnableFeedback_telemetry_feedback_enabled">Włącz mechanizmy opinii, takie jak reporter problemu, ankiety i inne opcje opinii.</string>
			<string id="TelemetryLevel">TelemetryLevel</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_policyDescription">Steruje poziomem telemetrii.</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_default">Wysyła dane użycia, błędy i raporty o awariach.</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_error">Wysyła ogólną telemetrię błędów i raporty o awariach.</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_crash">Wysyła raporty o awarii na poziomie systemu operacyjnego.</string>
			<string id="TelemetryLevel_telemetry_telemetryLevel_off">Wyłącza całkowicie telemetrię produktu.</string>
			<string id="UpdateMode">UpdateMode</string>
			<string id="UpdateMode_updateMode">Skonfiguruj, czy chcesz otrzymywać aktualizacje automatyczne. Wymaga ponownego uruchomienia po zmianie. Aktualizacje są pobierane z usługi online firmy Microsoft.</string>
			<string id="UpdateMode_none">Brak</string>
			<string id="UpdateMode_manual">Wyłącz automatyczne sprawdzanie aktualizacji w tle. Aktualizacje będą dostępne, jeśli wyszukasz aktualizacje ręcznie.</string>
			<string id="UpdateMode_start">Uruchamianie</string>
			<string id="UpdateMode_default">System</string>
		</stringTable>
